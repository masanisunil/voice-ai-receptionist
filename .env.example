NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_ai_receptionist?schema=public
APP_BASE_URL=http://localhost:8080
CLINIC_TIMEZONE=Asia/Kolkata
REQUEST_ID_HEADER=x-request-id
LOG_LEVEL=info

# Retell
RETELL_API_KEY=replace_me
RETELL_WEBHOOK_SECRET=replace_me
RETELL_AGENT_ID=replace_me
RETELL_PHONE_NUMBER=+10000000000

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1

# Mock PMS / Cliniko adapter
PMS_MODE=mock
PMS_BASE_URL=http://localhost:8080/api/pms/mock
PMS_API_KEY=local_mock_key
PMS_RETRY_ATTEMPTS=3

# Operational policy
SAME_DAY_BUFFER_MINUTES=30
RESCHEDULE_FEE_WINDOW_HOURS=24
DROPPED_CALL_RECOVERY_MINUTES=45
MISSED_CALLBACK_RECOVERY_HOURS=48
